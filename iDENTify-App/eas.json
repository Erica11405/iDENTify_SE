{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_PROJECT_ROOT": "./iDENTIfy-App"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_PROJECT_ROOT": "./iDENTIfy-App"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EAS_PROJECT_ROOT": "./iDENTIfy-App"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
